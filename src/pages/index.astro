<script>
window.addEventListener('DOMContentLoaded', () => {
  const heroImage = document.getElementById('hero-image');
  if (!heroImage) return;

  const colorButtons = document.querySelectorAll('[data-hero-color]');
  if (!colorButtons.length) return;

  const setActiveButton = (active: HTMLElement) => {
    colorButtons.forEach((button) => {
      button.classList.remove('border-4', 'border-primary', 'scale-110');
      button.classList.add('border-2', 'border-transparent');
    });
    active.classList.remove('border-2', 'border-transparent');
    active.classList.add('border-4', 'border-primary', 'scale-110');
  };

  colorButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const image = button.getAttribute('data-image');
      if (!image) return;
      heroImage.style.backgroundImage = `url('${image}')`;
      setActiveButton(button as HTMLElement);
    });
  });
});
</script>
