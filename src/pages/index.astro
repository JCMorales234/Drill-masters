---
import Layout from '../layouts/Layout.astro';
import heroNegro from '../assets/Pantalon drill negrov2.png';
import beigeOscuro from '../assets/Pantalon drill beige oscurov2.png';
import beigeClaro from '../assets/Pantalon drill beige clarov2.png';
---

<Layout>
<div class="sticky top-0 z-50 bg-white/95 dark:bg-background-dark/95 backdrop-blur-sm border-b-2 border-black dark:border-white/10">
<div class="max-w-[1200px] mx-auto px-6 lg:px-10 py-5 flex items-center justify-between">
<div class="flex items-center gap-3">
<div class="text-primary size-8">
<svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
<path d="M39.5563 34.1455V13.8546C39.5563 15.708 36.8773 17.3437 32.7927 18.3189C30.2914 18.916 27.263 19.2655 24 19.2655C20.737 19.2655 17.7086 18.916 15.2073 18.3189C11.1227 17.3437 8.44365 15.708 8.44365 13.8546V34.1455C8.44365 35.9988 11.1227 37.6346 15.2073 38.6098C17.7086 39.2069 20.737 39.5564 24 39.5564C27.1288 39.5564 30.2914 39.2069 32.7927 38.6098C36.8773 37.6346 39.5563 35.9988 39.5563 34.1455Z" fill="currentColor"></path>
<path clip-rule="evenodd" d="M10.4485 13.8519C10.4749 13.9271 10.6203 14.246 11.379 14.7361C12.298 15.3298 13.7492 15.9145 15.6717 16.3735C18.0007 16.9296 20.8712 17.2655 24 17.2655C27.1288 17.2655 29.9993 16.9296 32.3283 16.3735C34.2508 15.9145 35.702 15.3298 36.621 14.7361C37.3796 14.246 37.5251 13.9271 37.5515 13.8519C37.5287 13.7876 37.4333 13.5973 37.0635 13.2931C36.5266 12.8516 35.6288 12.3647 34.343 11.9175C31.79 11.0295 28.1333 10.4437 24 10.4437C19.8667 10.4437 16.2099 11.0295 13.657 11.9175C12.3712 12.3647 11.4734 12.8516 10.9365 13.2931C10.5667 13.5973 10.4713 13.7876 10.4485 13.8519ZM37.5563 18.7877C36.3176 19.3925 34.8502 19.8839 33.2571 20.2642C30.5836 20.9025 27.3973 21.2655 24 21.2655C20.6027 21.2655 17.4164 20.9025 14.7429 20.2642C13.1498 19.8839 11.6824 19.3925 10.4436 18.7877V34.1275C10.4515 34.1545 10.5427 34.4867 11.379 35.027C12.298 35.6207 13.7492 36.2054 15.6717 36.6644C18.0007 37.2205 20.8712 37.5564 24 37.5564C27.1288 37.5564 29.9993 37.2205 32.3283 36.6644C34.2508 36.2054 35.702 35.6207 36.621 35.027C37.4573 34.4867 37.5485 34.1546 37.5563 34.1275V18.7877ZM41.5563 13.8546V34.1455C41.5563 36.1078 40.158 37.5042 38.7915 38.3869C37.3498 39.3182 35.4192 40.0389 33.2571 40.5551C30.5836 41.1934 27.3973 41.5564 24 41.5564C20.6027 41.5564 17.4164 41.1934 14.7429 40.5551C12.5808 40.0389 10.6502 39.3182 9.20848 38.3869C7.84205 37.5042 6.44365 36.1078 6.44365 34.1455L6.44365 13.8546C6.44365 12.2684 7.37223 11.0454 8.39581 10.2036C9.43325 9.3505 10.8137 8.67141 12.343 8.13948C15.4203 7.06909 19.5418 6.44366 24 6.44366C28.4582 6.44366 32.5797 7.06909 35.657 8.13948C37.1863 8.67141 38.5667 9.3505 39.6042 10.2036C40.6278 11.0454 41.5563 12.2684 41.5563 13.8546Z" fill="currentColor" fill-rule="evenodd"></path>
</svg>
</div>
<h2 class="text-[#000000] dark:text-white text-2xl font-black leading-tight tracking-tighter">Drill Masters</h2>
</div>
		<div class="hidden md:flex items-center gap-8">
		<a class="text-xs uppercase font-black tracking-widest hover:text-primary transition-colors" href="#">Diseños</a>
		<a class="text-xs uppercase font-black tracking-widest hover:text-primary transition-colors" href="#calidad">Calidad</a>
<a class="text-xs uppercase font-black tracking-widest hover:text-primary transition-colors" href="#tallas">Tallas</a>
<a class="text-xs uppercase font-black tracking-widest hover:text-primary transition-colors" href="#faq">FAQ</a>
<button class="flex min-w-[120px] cursor-pointer items-center justify-center rounded-none h-11 px-6 bg-primary text-white text-xs font-black tracking-[0.2em] shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all">
<span>COMPRAR</span>
</button>
</div>
</div>
</div>
<section class="max-w-[1200px] mx-auto px-6 lg:px-10 py-12 md:py-24">
<div class="flex flex-col lg:flex-row gap-16 items-center">
<div class="w-full lg:w-1/2">
<div class="relative group">
<div class="absolute -inset-4 border-2 border-primary/20 -z-10 group-hover:-inset-6 transition-all duration-500"></div>
<div id="hero-image" class="relative w-full aspect-[4/5] bg-center bg-no-repeat bg-cover shadow-2xl overflow-hidden transition-all duration-700 group-hover:scale-105" style={`background-image: url('${heroNegro.src}');`}>
<div class="absolute bottom-6 left-6 bg-primary text-white px-4 py-2 text-xs font-black tracking-[0.3em] uppercase">Edición Premium</div>
</div>
</div>
</div>
<div class="w-full lg:w-1/2 flex flex-col gap-10">
<div class="flex flex-col gap-5">
<span class="inline-flex items-center px-4 py-1 bg-black text-white dark:bg-white dark:text-black text-[10px] font-black uppercase tracking-[0.3em] w-fit">Artesanía Nacional</span>
<h1 class="text-black dark:text-white text-6xl md:text-8xl font-black leading-[0.9] tracking-tighter">
                    Pantalón de Drill Premium: <span class="text-primary">Estilo y Confort</span>
</h1>
<p class="text-gray-600 dark:text-gray-400 text-lg md:text-xl font-medium leading-relaxed max-w-lg">
                    Experimenta el ajuste perfecto con nuestra artesanía nacional. Diseñados para durar y ofrecer la máxima comodidad en cualquier entorno urbano.
                </p>
</div>
<div class="flex flex-col gap-8 p-8 bg-white dark:bg-black border-4 border-black dark:border-white shadow-[12px_12px_0px_0px_rgba(59,130,246,1)]">
<div class="flex flex-col gap-4">
<span class="text-xs font-black uppercase tracking-[0.2em] text-gray-500">Selecciona tu color</span>
<div class="flex gap-4">
<button class="size-12 rounded-full border-4 border-primary bg-[#000000] scale-110" title="Negro" data-hero-color="negro" data-image={heroNegro.src}></button>
<button class="size-12 rounded-full border-2 border-transparent bg-[#f0ddc0] hover:scale-105 transition-transform" title="Beige claro" data-hero-color="beige-claro" data-image={beigeClaro.src}></button>
<button class="size-12 rounded-full border-2 border-transparent bg-[#d4b483] hover:scale-105 transition-transform" title="Beige oscuro" data-hero-color="beige-oscuro" data-image={beigeOscuro.src}></button>
</div>
</div>
<div class="flex flex-col gap-4">
<div class="flex justify-between items-end">
<span class="text-xs font-black uppercase tracking-[0.2em] text-gray-500">Tallas disponibles</span>
<a class="text-[10px] font-black text-primary underline decoration-2 underline-offset-4 tracking-widest uppercase" href="#tallas">Guía de tallas</a>
</div>
<div class="grid grid-cols-5 gap-3">
<div class="h-12 border-2 border-black dark:border-white flex items-center justify-center text-sm font-black">28</div>
<div class="h-12 border-2 border-black dark:border-white flex items-center justify-center text-sm font-black">30</div>
<div class="h-12 border-2 border-black dark:border-white flex items-center justify-center text-sm font-black">32</div>
<div class="h-12 border-2 border-black dark:border-white flex items-center justify-center text-sm font-black">34</div>
<div class="h-12 border-2 border-black dark:border-white flex items-center justify-center text-sm font-black">36</div>
</div>
</div>
<button class="w-full flex cursor-pointer items-center justify-center h-16 bg-black dark:bg-primary text-white text-xl font-black tracking-[0.2em] hover:bg-primary dark:hover:bg-white dark:hover:text-black transition-all group">
<span class="truncate">COMPRAR AHORA</span>
<span class="material-symbols-outlined ml-2 group-hover:translate-x-2 transition-transform">arrow_forward</span>
</button>
<div class="flex items-center justify-center gap-2 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mt-2">
<span class="material-symbols-outlined text-sm">local_shipping</span>
<span>Envío Gratis</span>
</div>
</div>
</div>
</div>
</section>
<section id="calidad" class="bg-black text-white py-24 overflow-hidden">
<div class="max-w-[1200px] mx-auto px-6 lg:px-10">
<div class="flex flex-col gap-6 mb-16 relative">
<h2 class="text-6xl md:text-7xl font-black leading-none tracking-tighter italic">
                Calidad <br/><span class="text-primary not-italic">En Detalle</span>
</h2>
<p class="text-gray-400 text-lg max-w-[600px] font-medium border-l-4 border-primary pl-6">
                Nuestros pantalones están diseñados pensando en la versatilidad y el rendimiento diario del hombre moderno.
            </p>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-2 border-white/20">
<div class="flex flex-col gap-6 p-10 border-b md:border-b-0 md:border-r border-white/20 hover:bg-primary transition-colors group">
<div class="text-white bg-white/10 size-16 flex items-center justify-center group-hover:bg-white group-hover:text-primary">
<span class="material-symbols-outlined text-3xl">straighten</span>
</div>
<div class="flex flex-col gap-4">
<h3 class="text-2xl font-black tracking-tight">Elasticidad Superior</h3>
<p class="text-gray-400 group-hover:text-white text-base leading-relaxed">Tela stretch de alta tecnología que se adapta a tus movimientos sin perder su forma original.</p>
</div>
</div>
<div class="flex flex-col gap-6 p-10 border-b md:border-b-0 md:border-r border-white/20 hover:bg-primary transition-colors group">
<div class="text-white bg-white/10 size-16 flex items-center justify-center group-hover:bg-white group-hover:text-primary">
<span class="material-symbols-outlined text-3xl">shield_with_heart</span>
</div>
<div class="flex flex-col gap-4">
<h3 class="text-2xl font-black tracking-tight">Máxima Durabilidad</h3>
<p class="text-gray-400 group-hover:text-white text-base leading-relaxed">Costuras reforzadas y drill de gramaje pesado para resistir el uso constante y el paso del tiempo.</p>
</div>
</div>
<div class="flex flex-col gap-6 p-10 hover:bg-primary transition-colors group">
<div class="text-white bg-white/10 size-16 flex items-center justify-center group-hover:bg-white group-hover:text-primary">
<span class="material-symbols-outlined text-3xl">auto_awesome</span>
</div>
<div class="flex flex-col gap-4">
<h3 class="text-2xl font-black tracking-tight">Acabados de Lujo</h3>
<p class="text-gray-400 group-hover:text-white text-base leading-relaxed">Botones de alta resistencia y detalles de precisión que marcan la diferencia en tu look diario.</p>
</div>
</div>
</div>
</div>
</section>
<section class="max-w-[1200px] mx-auto px-6 lg:px-10 py-24" id="tallas">
<div class="flex flex-col gap-16">
<div class="flex flex-col gap-6 text-center max-w-[800px] mx-auto">
<h2 class="text-5xl md:text-6xl font-black tracking-tighter">
                Tabla de Tallas
            </h2>
<div class="h-1 w-24 bg-primary mx-auto"></div>
<p class="text-gray-600 dark:text-gray-400 text-lg font-medium">
                Encuentra tu ajuste ideal comparando tus medidas con nuestra guía. Si estás entre dos tallas, te recomendamos elegir la más grande.
            </p>
</div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
<div class="overflow-x-auto border-2 border-black dark:border-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_rgba(255,255,255,0.1)]">
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-black text-white">
<th class="p-5 font-black text-xs uppercase tracking-[0.2em]">Talla</th>
<th class="p-5 font-black text-xs uppercase tracking-[0.2em]">Cintura (cm)</th>
<th class="p-5 font-black text-xs uppercase tracking-[0.2em]">Largo (cm)</th>
<th class="p-5 font-black text-xs uppercase tracking-[0.2em]">Cadera (cm)</th>
</tr>
</thead>
<tbody class="divide-y divide-black/10 dark:divide-white/10 bg-white dark:bg-transparent">
<tr class="hover:bg-primary hover:text-white transition-colors">
<td class="p-5 font-black">28</td>
<td class="p-5 font-medium">72-76</td>
<td class="p-5 font-medium">102</td>
<td class="p-5 font-medium">92-96</td>
</tr>
<tr class="hover:bg-primary hover:text-white transition-colors">
<td class="p-5 font-black">30</td>
<td class="p-5 font-medium">78-82</td>
<td class="p-5 font-medium">104</td>
<td class="p-5 font-medium">98-102</td>
</tr>
<tr class="hover:bg-primary hover:text-white transition-colors">
<td class="p-5 font-black">32</td>
<td class="p-5 font-medium">84-88</td>
<td class="p-5 font-medium">106</td>
<td class="p-5 font-medium">104-108</td>
</tr>
<tr class="hover:bg-primary hover:text-white transition-colors">
<td class="p-5 font-black">34</td>
<td class="p-5 font-medium">90-94</td>
<td class="p-5 font-medium">108</td>
<td class="p-5 font-medium">110-114</td>
</tr>
<tr class="hover:bg-primary hover:text-white transition-colors">
<td class="p-5 font-black">36</td>
<td class="p-5 font-medium">96-100</td>
<td class="p-5 font-medium">110</td>
<td class="p-5 font-medium">116-120</td>
</tr>
</tbody>
</table>
</div>
<div class="flex flex-col gap-10">
<h3 class="text-2xl font-black flex items-center gap-3">
<span class="material-symbols-outlined text-primary text-4xl">info</span>
                    ¿Cómo medirte correctamente?
                </h3>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="flex flex-col gap-4 p-6 border-l-4 border-black dark:border-white bg-white dark:bg-white/5">
<div class="text-primary font-black text-4xl">01</div>
<h4 class="font-black text-xs uppercase tracking-widest">Cintura</h4>
<p class="text-xs text-gray-500 font-medium">Mide alrededor de la línea natural de tu cintura, justo encima del ombligo.</p>
</div>
<div class="flex flex-col gap-4 p-6 border-l-4 border-black dark:border-white bg-white dark:bg-white/5">
<div class="text-primary font-black text-4xl">02</div>
<h4 class="font-black text-xs uppercase tracking-widest">Cadera</h4>
<p class="text-xs text-gray-500 font-medium">Mide la parte más ancha de tus caderas manteniendo la cinta horizontal.</p>
</div>
<div class="flex flex-col gap-4 p-6 border-l-4 border-black dark:border-white bg-white dark:bg-white/5">
<div class="text-primary font-black text-4xl">03</div>
<h4 class="font-black text-xs uppercase tracking-widest">Largo</h4>
<p class="text-xs text-gray-500 font-medium">Mide desde la parte superior de la cintura hasta el final de la pierna.</p>
</div>
</div>
<div class="p-8 bg-primary text-white flex items-center gap-6 shadow-xl">
<span class="material-symbols-outlined text-4xl">straighten</span>
<p class="text-sm font-bold italic tracking-wide uppercase">
                        "Un buen ajuste es la clave de la elegancia. Si tienes dudas, contáctanos por WhatsApp para asesoría personalizada."
                    </p>
</div>
</div>
</div>
</div>
</section>
<section class="max-w-[1200px] mx-auto px-6 lg:px-10 py-24 bg-gray-100 dark:bg-white/5">
<div class="flex items-center justify-between mb-16 border-b-4 border-black dark:border-white pb-6">
<h2 class="text-5xl md:text-6xl font-black tracking-tighter">Elige tu Estilo</h2>
<div class="flex gap-4">
<button class="size-14 flex items-center justify-center bg-white dark:bg-black border-2 border-black dark:border-white hover:bg-primary hover:text-white transition-all">
<span class="material-symbols-outlined text-2xl">chevron_left</span>
</button>
<button class="size-14 flex items-center justify-center bg-white dark:bg-black border-2 border-black dark:border-white hover:bg-primary hover:text-white transition-all">
<span class="material-symbols-outlined text-2xl">chevron_right</span>
</button>
</div>
</div>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12">
<div class="group flex flex-col gap-6">
<div class="w-full aspect-square bg-center bg-no-repeat bg-cover shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all duration-500 group-hover:scale-105" style={`background-image: url('${heroNegro.src}');`}>
</div>
<div class="flex justify-between items-center px-2">
<h4 class="font-black text-xl tracking-tight">Negro</h4>

</div>
</div>
<div class="group flex flex-col gap-6">
<div class="w-full aspect-square bg-center bg-no-repeat bg-cover shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all duration-500 group-hover:scale-105" style={`background-image: url('${beigeOscuro.src}');`}>
</div>
<div class="flex justify-between items-center px-2">
<h4 class="font-black text-xl tracking-tight">Beige oscuro</h4>

</div>
</div>
<div class="group flex flex-col gap-6">
<div class="w-full aspect-square bg-center bg-no-repeat bg-cover shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all duration-500 group-hover:scale-105" style={`background-image: url('${beigeClaro.src}');`}>
</div>
<div class="flex justify-between items-center px-2">
<h4 class="font-black text-xl tracking-tight">Beige claro</h4>

</div>
</div>
</div>
</section>
<section class="max-w-[1200px] mx-auto px-6 lg:px-10 py-24" id="faq">
<div class="max-w-[800px] mx-auto">
<div class="flex flex-col gap-6 text-center mb-20">
<h2 class="text-5xl md:text-6xl font-black tracking-tighter">
                Preguntas Frecuentes
            </h2>
<div class="h-1 w-24 bg-primary mx-auto"></div>
<p class="text-gray-600 dark:text-gray-400 text-lg font-medium">
                Resolvemos tus dudas para que realices tu compra con total confianza.
            </p>
</div>
<div class="flex flex-col gap-4">
<div class="faq-accordion bg-white dark:bg-white/5 border-2 border-black dark:border-white/20 p-6 md:p-8 hover:border-primary transition-all">
<input class="hidden" id="faq-1" name="faq-group" type="checkbox"/>
<label class="faq-header flex justify-between items-center cursor-pointer group" for="faq-1">
<h3 class="text-black dark:text-white font-black text-xl tracking-tight group-hover:text-primary transition-colors">¿Cuál es el tiempo de envío?</h3>
<span class="faq-icon material-symbols-outlined text-black dark:text-white transition-transform duration-300">expand_more</span>
</label>
<div class="faq-content text-gray-600 dark:text-gray-400 text-base font-medium leading-relaxed">
                    Realizamos envíos a todo el país. El tiempo estimado de entrega es de 2 a 5 días hábiles, dependiendo de tu ubicación. Una vez despachado, recibirás un número de guía para rastrear tu pedido.
                </div>
</div>
<div class="faq-accordion bg-white dark:bg-white/5 border-2 border-black dark:border-white/20 p-6 md:p-8 hover:border-primary transition-all">
<input class="hidden" id="faq-2" name="faq-group" type="checkbox"/>
<label class="faq-header flex justify-between items-center cursor-pointer group" for="faq-2">
<h3 class="text-black dark:text-white font-black text-xl tracking-tight group-hover:text-primary transition-colors">¿Cómo puedo realizar un cambio de talla?</h3>
<span class="faq-icon material-symbols-outlined text-black dark:text-white transition-transform duration-300">expand_more</span>
</label>
<div class="faq-content text-gray-600 dark:text-gray-400 text-base font-medium leading-relaxed">
                    Si la talla no es la correcta, tienes hasta 30 días para solicitar un cambio. El producto debe estar en perfectas condiciones y con sus etiquetas originales. Contáctanos por WhatsApp para gestionar la logística de devolución.
                </div>
</div>
<div class="faq-accordion bg-white dark:bg-white/5 border-2 border-black dark:border-white/20 p-6 md:p-8 hover:border-primary transition-all">
<input class="hidden" id="faq-3" name="faq-group" type="checkbox"/>
<label class="faq-header flex justify-between items-center cursor-pointer group" for="faq-3">
<h3 class="text-black dark:text-white font-black text-xl tracking-tight group-hover:text-primary transition-colors">¿Qué cuidados requiere el tejido de drill?</h3>
<span class="faq-icon material-symbols-outlined text-black dark:text-white transition-transform duration-300">expand_more</span>
</label>
<div class="faq-content text-gray-600 dark:text-gray-400 text-base font-medium leading-relaxed">
                    Recomendamos lavar la prenda al revés con agua fría y colores similares. No usar blanqueadores potentes y secar a la sombra para preservar el color original por más tiempo. Si usas secadora, hazlo en ciclo delicado.
                </div>
</div>
<div class="faq-accordion bg-white dark:bg-white/5 border-2 border-black dark:border-white/20 p-6 md:p-8 hover:border-primary transition-all">
<input class="hidden" id="faq-4" name="faq-group" type="checkbox"/>
<label class="faq-header flex justify-between items-center cursor-pointer group" for="faq-4">
<h3 class="text-black dark:text-white font-black text-xl tracking-tight group-hover:text-primary transition-colors">¿Tienen tienda física?</h3>
<span class="faq-icon material-symbols-outlined text-black dark:text-white transition-transform duration-300">expand_more</span>
</label>
<div class="faq-content text-gray-600 dark:text-gray-400 text-base font-medium leading-relaxed">
                    Actualmente operamos exclusivamente de forma online. Esto nos permite reducir costos y ofrecerte la mejor calidad de drill nacional a un precio competitivo, con la garantía de que si no te gusta, lo puedes devolver.
                </div>
</div>
</div>
</div>
</section>
<footer class="bg-black text-white py-24">
<div class="max-w-[1200px] mx-auto px-6 lg:px-10 grid grid-cols-1 md:grid-cols-3 gap-16 md:justify-items-center">
<div class="col-span-1 md:col-span-1 flex flex-col gap-8">
<div class="flex items-center gap-3">
