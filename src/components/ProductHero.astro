---
import heroNegro from '../assets/Pantalon drill negrov2.png';
import beigeOscuro from '../assets/Pantalon drill beige oscurov2.png';
import beigeClaro from '../assets/Pantalon drill beige clarov2.png';
---

<section class="max-w-[1200px] mx-auto px-6 lg:px-10 py-12 md:py-24">
  <div class="flex flex-col lg:flex-row gap-16 items-center">
    <div class="w-full lg:w-1/2">
      <div class="relative group">
        <div class="absolute -inset-4 border-2 border-primary/20 -z-10 group-hover:-inset-6 transition-all duration-500"></div>
        <div id="hero-image" class="relative w-full aspect-[4/5] bg-center bg-no-repeat bg-cover shadow-2xl overflow-hidden transition-all duration-700 group-hover:scale-105" style={`background-image: url('${heroNegro.src}');`}>
          <div class="absolute bottom-6 left-6 bg-primary text-white px-4 py-2 text-xs font-black tracking-[0.3em] uppercase">Edición Premium</div>
        </div>
      </div>
    </div>
    <div class="w-full lg:w-1/2 flex flex-col gap-10">
      <div class="flex flex-col gap-5">
        <span class="inline-flex items-center px-4 py-1 bg-black text-white dark:bg-white dark:text-black text-[10px] font-black uppercase tracking-[0.3em] w-fit">Artesanía Nacional</span>
        <h1 class="text-black dark:text-white text-6xl md:text-8xl font-black leading-[0.9] tracking-tighter">
          Pantalón de Drill Premium: <span class="text-primary">Estilo y Confort</span>
        </h1>
        <p class="text-gray-600 dark:text-gray-400 text-lg md:text-xl font-medium leading-relaxed max-w-lg">
          Experimenta el ajuste perfecto con nuestra artesanía nacional. Diseñados para durar y ofrecer la máxima comodidad en cualquier entorno urbano.
        </p>
        <div class="flex items-center gap-4 mt-2">
            <div class="flex flex-col">
                <span class="text-gray-400 dark:text-gray-500 text-xl font-bold line-through decoration-red-500/70">$110.000</span>
                <span class="text-5xl md:text-6xl font-black text-black dark:text-white tracking-tighter">$90.000</span>
            </div>
            <span class="bg-primary text-white text-xs font-black px-3 py-1 uppercase tracking-widest -rotate-2 self-end mb-2">
                Oferta Lanzamiento
            </span>
        </div>
      </div>
      <div class="flex flex-col gap-8 p-8 bg-white dark:bg-black border-4 border-black dark:border-white shadow-[12px_12px_0px_0px_rgba(59,130,246,1)]">
        <div class="flex flex-col gap-4">
          <span class="text-xs font-black uppercase tracking-[0.2em] text-gray-500">Selecciona tu color</span>
          <div class="flex gap-4">
            <button class="size-12 rounded-full border-4 border-primary bg-[#000000] scale-110" aria-label="Seleccionar color Negro" title="Negro" data-hero-color="negro" data-image={heroNegro.src}></button>
            <button class="size-12 rounded-full border-2 border-transparent bg-[#f0ddc0] hover:scale-105 transition-transform" aria-label="Seleccionar color Beige claro" title="Beige claro" data-hero-color="beige-claro" data-image={beigeClaro.src}></button>
            <button class="size-12 rounded-full border-2 border-transparent bg-[#d4b483] hover:scale-105 transition-transform" aria-label="Seleccionar color Beige oscuro" title="Beige oscuro" data-hero-color="beige-oscuro" data-image={beigeOscuro.src}></button>
          </div>
        </div>
        <div class="flex flex-col gap-4">
          <div class="flex justify-between items-end">
            <span class="text-xs font-black uppercase tracking-[0.2em] text-gray-500">Tallas disponibles</span>
            <a class="text-[10px] font-black text-primary underline decoration-2 underline-offset-4 tracking-widest uppercase" href="#tallas">Guía de tallas</a>
          </div>
          <div class="grid grid-cols-5 gap-3">
            <button class="h-12 border-2 border-black dark:border-white flex items-center justify-center text-sm font-black hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all" data-size="28">28</button>
            <button class="h-12 border-2 border-primary bg-primary text-white flex items-center justify-center text-sm font-black" data-size="30">30</button>
            <button class="h-12 border-2 border-black dark:border-white flex items-center justify-center text-sm font-black hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all" data-size="32">32</button>
            <button class="h-12 border-2 border-black dark:border-white flex items-center justify-center text-sm font-black hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all" data-size="34">34</button>
            <button class="h-12 border-2 border-black dark:border-white flex items-center justify-center text-sm font-black hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all" data-size="36">36</button>
          </div>
        </div>
        <button data-buy-now class="w-full flex cursor-pointer items-center justify-center h-16 bg-black dark:bg-white text-white dark:text-black text-xl font-black tracking-[0.2em] hover:bg-primary dark:hover:bg-primary dark:hover:text-white transition-all group">
        <span class="truncate">COMPRAR AHORA</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 ml-2 group-hover:translate-x-2 transition-transform">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
      </button>
        <div class="flex items-center justify-center gap-2 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mt-2">
          <span class="material-symbols-outlined text-sm">local_shipping</span>
          <span>Envío Gratis</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Script interactive logic
  window.addEventListener('DOMContentLoaded', () => {
    const heroImage = document.getElementById('hero-image');
    const colorButtons = document.querySelectorAll<HTMLButtonElement>('[data-hero-color]');
    const sizeButtons = document.querySelectorAll<HTMLButtonElement>('[data-size]');
    const buyButton = document.querySelector<HTMLButtonElement>('[data-buy-now]');
  
    if (!heroImage || !colorButtons.length) return;
  
    let selection = {
      color: 'negro',
      size: '30',
    };
  
    try {
      const stored = localStorage.getItem('drillSelection');
      if (stored) {
        const parsed = JSON.parse(stored);
        if (parsed && typeof parsed === 'object') {
          if (parsed.color) selection.color = String(parsed.color);
          if (parsed.size) selection.size = String(parsed.size);
        }
      }
    } catch (error) {
    }
  
    const saveSelection = () => {
      try {
        localStorage.setItem('drillSelection', JSON.stringify(selection));
      } catch (error) {
      }
    };
  
    const setActiveColorButton = (active: HTMLButtonElement) => {
      colorButtons.forEach((button) => {
        button.classList.remove('border-4', 'border-primary', 'scale-110');
        button.classList.add('border-2', 'border-transparent');
      });
      active.classList.remove('border-2', 'border-transparent');
      active.classList.add('border-4', 'border-primary', 'scale-110');
    };
  
    const setActiveSizeButton = (active: HTMLButtonElement) => {
      sizeButtons.forEach((button) => {
        button.classList.remove('border-primary', 'bg-primary', 'text-white');
        button.classList.add('border-black', 'dark:border-white');
      });
      active.classList.remove('border-black', 'dark:border-white');
      active.classList.add('border-primary', 'bg-primary', 'text-white');
    };
  
    const applyColorFromSelection = () => {
      const buttonsArray = Array.from(colorButtons);
      const target =
        buttonsArray.find(
          (button) => button.getAttribute('data-hero-color') === selection.color
        ) || buttonsArray[0];
  
      if (!target) return;
  
      const image = target.getAttribute('data-image');
      if (image) {
        heroImage.style.backgroundImage = `url('${image}')`;
      }
      setActiveColorButton(target);
    };
  
    const applySizeFromSelection = () => {
      if (!sizeButtons.length) return;
      const buttonsArray = Array.from(sizeButtons);
      const target =
        buttonsArray.find((button) => button.getAttribute('data-size') === selection.size) ||
        buttonsArray[0];
  
      if (!target) return;
      setActiveSizeButton(target);
    };
  
    colorButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const image = button.getAttribute('data-image');
        const color = button.getAttribute('data-hero-color');
        if (image) {
          heroImage.style.backgroundImage = `url('${image}')`;
        }
        if (color) {
          selection.color = color;
          saveSelection();
        }
        setActiveColorButton(button);
      });
    });
  
    // Add TypeScript type annotations to size button event listener
    sizeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const size = button.getAttribute('data-size');
        if (!size) return;
        selection.size = size;
        saveSelection();
        setActiveSizeButton(button);
      });
    });
  
    if (buyButton) {
      buyButton.addEventListener('click', () => {
        if (!selection.color || !selection.size) {
          alert('Por favor selecciona un color y una talla antes de continuar.');
          return;
        }
  
        const colorLabelMap: Record<string, string> = {
          'negro': 'Negro',
          'beige-claro': 'Beige claro',
          'beige-oscuro': 'Beige oscuro',
        };

        const validSizes = ['28', '30', '32', '34', '36'];
  
        // Strict validation to prevent data tampering
        const colorLabel = colorLabelMap[selection.color];
        if (!colorLabel) {
             alert('Error: Color seleccionado no válido.');
             return;
        }

        if (!validSizes.includes(selection.size)) {
             alert('Error: Talla seleccionada no válida.');
             return;
        }

      // Using the number provided by user: 573104574348
      const phone = '573104574348';
      const message = `¡Hola! Me interesa comprar el pantalón:\n- Color: ${colorLabel}\n- Talla: ${selection.size}\n\n¿Está disponible para envío inmediato?`;
        
        const url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;

        window.open(url, '_blank', 'noopener,noreferrer');
      });
    }
  
    applyColorFromSelection();
    applySizeFromSelection();
  });
</script>
